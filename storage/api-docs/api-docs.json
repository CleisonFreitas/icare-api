{
    "openapi": "3.0.0",
    "info": {
        "title": "Icare Pet API",
        "description": "API para gerenciamento de clínicas de pet shop",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8081",
            "description": "Servidor principal"
        }
    ],
    "paths": {
        "/api/v1/administrador/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Login do administrador",
                "operationId": "b365e50b1043617749b87f6d270f68d5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Credenciais inválidas"
                    },
                    "422": {
                        "description": "Erro de validação",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/administrador/logout": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Logout do administrador",
                "description": "Remove o token atual do usuário autenticado",
                "operationId": "56dd5c72381df1ab0c5e70ff96369373",
                "responses": {
                    "200": {
                        "description": "Logout realizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LogoutResponse"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Usuário não autenticado ou token inválido"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/administrador/me": {
            "get": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Retorna os dados do administrador autenticado",
                "description": "Valida o token atual e retorna os dados do usuário autenticado",
                "operationId": "0b270e6107ca6a2f728d2a23a7d545ee",
                "responses": {
                    "200": {
                        "description": "Usuário autenticado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Não autenticado, token inválido ou expirado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/administrador/gerar-pin": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Gera PIN para recuperação de senha",
                "description": "Gera um código PIN de 4 dígitos e envia por email para o usuário",
                "operationId": "237c15f38e2150b25462d9463b19b1f5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/GerarPinRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "PIN gerado e enviado com sucesso"
                    },
                    "400": {
                        "description": "Email não encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BadRequestError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erro de validação",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/administrador/validar-pin": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Valida PIN de recuperação de senha",
                "description": "Valida se o PIN informado é válido e não expirou",
                "operationId": "5bbdc30d84f16e78eedde65e2ed0c755",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ValidarPinRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "PIN válido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PinValidadoResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PIN inválido ou expirado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BadRequestError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erro de validação",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/administrador/alterar-senha": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Altera a senha do usuário usando PIN",
                "description": "Valida o PIN e altera a senha do usuário",
                "operationId": "542991d91767ed78e3edeb99a71d96b5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AlterarSenhaRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Senha alterada com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SenhaAlteradaSchema"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PIN inválido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BadRequestError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/administrador/cliente": {
            "get": {
                "tags": [
                    "Cliente"
                ],
                "summary": "Lista clientes com filtros e paginação",
                "operationId": "eed1c7879af6b5069b8cd1a2d00da070",
                "parameters": [
                    {
                        "name": "nome",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "documento",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "data_nascimento[inicio]",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "data_nascimento[fim]",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "limite",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "example": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de clientes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedClienteResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Cliente"
                ],
                "summary": "Cadastrar novo cliente",
                "operationId": "7f8c1bcf1633dc05639af91aa807ce33",
                "requestBody": {
                    "description": "Dados para criação do cliente",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ClienteStoreRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Cliente criado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Cliente"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erro de validação"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/administrador/cliente/{id}": {
            "get": {
                "tags": [
                    "Cliente"
                ],
                "summary": "Busca cliente por ID",
                "operationId": "347bc5c2aa305f8f881c1e58fd5834f9",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Cliente encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Cliente"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Cliente não encontrado"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Cliente"
                ],
                "summary": "Atualizar cliente",
                "operationId": "a6a3b459448f68d8010246d4c61a4a56",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do cliente",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ClienteUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Cliente atualizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Cliente"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Cliente não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Cliente"
                ],
                "summary": "Remover cliente",
                "operationId": "fc8c281734bbefb49e67c21f945f1716",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Cliente removido com sucesso"
                    },
                    "404": {
                        "description": "Cliente não encontrado"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "AlterarSenhaRequest": {
                "required": [
                    "email",
                    "pin",
                    "senha",
                    "senha_confirmation"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@email.com"
                    },
                    "pin": {
                        "description": "PIN enviado por email",
                        "type": "string",
                        "example": "123456"
                    },
                    "senha": {
                        "type": "string",
                        "format": "password",
                        "minLength": 6,
                        "example": "novasenha123"
                    },
                    "senha_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "novasenha123"
                    }
                },
                "type": "object"
            },
            "ClienteStoreRequest": {
                "required": [
                    "nome",
                    "email",
                    "documento",
                    "endereco"
                ],
                "properties": {
                    "nome": {
                        "type": "string",
                        "maxLength": 255,
                        "example": "João Silva"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao@email.com"
                    },
                    "documento": {
                        "type": "string",
                        "maxLength": 11,
                        "example": "12345678900"
                    },
                    "data_nascimento": {
                        "type": "string",
                        "format": "date",
                        "example": "1990-01-01",
                        "nullable": true
                    },
                    "endereco": {
                        "$ref": "#/components/schemas/Endereco"
                    },
                    "contatos": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Contato"
                        },
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ClienteUpdateRequest": {
                "required": [
                    "nome",
                    "email",
                    "documento"
                ],
                "properties": {
                    "nome": {
                        "type": "string",
                        "example": "João Atualizado"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao@email.com"
                    },
                    "documento": {
                        "type": "string",
                        "example": "12345678900"
                    }
                },
                "type": "object"
            },
            "GerarPinRequest": {
                "required": [
                    "email"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@email.com"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "email",
                    "senha"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@email.com"
                    },
                    "senha": {
                        "type": "string",
                        "format": "password",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "ValidarPinRequest": {
                "required": [
                    "email",
                    "pin"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@email.com"
                    },
                    "pin": {
                        "description": "PIN de 4 dígitos enviado por email",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "BadRequestError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Email informado não foi encontrado!"
                    }
                },
                "type": "object"
            },
            "BasePaginatedResponse": {
                "properties": {
                    "links": {
                        "properties": {
                            "first": {
                                "type": "string",
                                "nullable": true
                            },
                            "last": {
                                "type": "string",
                                "nullable": true
                            },
                            "prev": {
                                "type": "string",
                                "nullable": true
                            },
                            "next": {
                                "type": "string",
                                "nullable": true
                            }
                        },
                        "type": "object"
                    },
                    "meta": {
                        "properties": {
                            "current_page": {
                                "type": "integer"
                            },
                            "from": {
                                "type": "integer",
                                "nullable": true
                            },
                            "last_page": {
                                "type": "integer"
                            },
                            "path": {
                                "type": "string"
                            },
                            "per_page": {
                                "type": "integer"
                            },
                            "to": {
                                "type": "integer",
                                "nullable": true
                            },
                            "total": {
                                "type": "integer"
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "usuario": {
                        "$ref": "#/components/schemas/Usuario"
                    },
                    "token": {
                        "type": "string",
                        "example": "1|asdhjkasdhjkashdkjashdkjashdk"
                    }
                },
                "type": "object"
            },
            "LogoutResponse": {
                "properties": {
                    "usuario": {
                        "$ref": "#/components/schemas/Usuario"
                    },
                    "token": {
                        "type": "string",
                        "example": "admin-token",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "PaginatedClienteResponse": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/BasePaginatedResponse"
                    },
                    {
                        "properties": {
                            "data": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Cliente"
                                }
                            }
                        },
                        "type": "object"
                    }
                ]
            },
            "PinValidadoResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "PIN válido."
                    }
                },
                "type": "object"
            },
            "SenhaAlteradaSchema": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Senha alterada com sucesso."
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "O campo email é obrigatório."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "type": "object"
            },
            "Cliente": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "nome": {
                        "type": "string",
                        "example": "João Silva"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao@email.com"
                    },
                    "documento": {
                        "type": "string",
                        "example": "12345678900"
                    },
                    "data_nascimento": {
                        "type": "string",
                        "format": "date",
                        "example": "1990-01-01",
                        "nullable": true
                    },
                    "endereco": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/Endereco"
                            }
                        ],
                        "nullable": true
                    },
                    "contatos": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ContatoResponse"
                        },
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ContatoResponse": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "tipo": {
                        "type": "string",
                        "example": "telefone"
                    },
                    "valor": {
                        "type": "string",
                        "example": "(11)99999-9999"
                    }
                },
                "type": "object"
            },
            "Contato": {
                "required": [
                    "tipo",
                    "valor"
                ],
                "properties": {
                    "tipo": {
                        "type": "string",
                        "example": "telefone"
                    },
                    "valor": {
                        "type": "string",
                        "example": "(11)99999-9999"
                    }
                },
                "type": "object"
            },
            "Endereco": {
                "required": [
                    "cep",
                    "logradouro",
                    "numero",
                    "bairro",
                    "cidade",
                    "pais"
                ],
                "properties": {
                    "cep": {
                        "type": "string",
                        "example": "01001000"
                    },
                    "logradouro": {
                        "type": "string",
                        "example": "Rua das Flores"
                    },
                    "numero": {
                        "type": "integer",
                        "example": 123
                    },
                    "complemento": {
                        "type": "string",
                        "example": "Apto 12",
                        "nullable": true
                    },
                    "bairro": {
                        "type": "string",
                        "example": "Centro"
                    },
                    "cidade": {
                        "type": "string",
                        "example": "São Paulo"
                    },
                    "pais": {
                        "type": "string",
                        "example": "Brasil"
                    }
                },
                "type": "object"
            },
            "Usuario": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nome": {
                        "type": "string",
                        "example": "Administrador"
                    },
                    "email": {
                        "type": "string",
                        "example": "admin@email.com"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Autenticação",
            "description": "Autenticação"
        },
        {
            "name": "Cliente",
            "description": "Cliente"
        }
    ]
}